PORT=8788
CHAT_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# DeepSeek chat model.
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-v4-flash

# Qingyun AI aggregate image generation.
API_KEY=
QINGYUN_API_BASE_URL=https://api.lk888.ai/api
QINGYUN_IMAGE_MODEL=gpt-image-2
QINGYUN_IMAGE_ASPECT_RATIO=16:9
QINGYUN_IMAGE_SIZE=2K
QINGYUN_POLL_INTERVAL_MS=5000
QINGYUN_TASK_TIMEOUT_MS=1800000

# Tencent Cloud COS asset storage.
COS_SECRET_ID=
COS_SECRET_KEY=
COS_BUCKET=
COS_REGION=ap-guangzhou
COS_PUBLIC_BASE_URL=

# Optional: api internal asset persistence endpoint.
API_INTERNAL_ASSET_ENDPOINT=
API_INTERNAL_TOKEN=
